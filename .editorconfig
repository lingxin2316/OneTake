# EditorConfig 跨编辑器格式统一规范 https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# Markdown：保留行尾两空格（换行语义），不裁剪
[*.md]
trim_trailing_whitespace = false
max_line_length = off

# Web 原型（TS/JS/CSS/HTML/JSON）使用 2 空格缩进
[*.{ts,tsx,js,jsx,mjs,cjs,css,html,json,jsonc,yml,yaml}]
indent_size = 2

# Gradle Kotlin DSL 与 properties
[*.{kt,kts,java,properties,gradle}]
indent_size = 4

# Shell 与 Makefile 必须用 tab
[*.sh]
indent_style = tab

[Makefile]
indent_style = tab
